{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Typst Academic Paper Schema",
  "type": "object",
  "properties": {
    "title": { "type": "string", "description": "Paper title. Supports Typst markup." },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "affiliation": { "type": "string" }
        },
        "required": ["name", "affiliation"]
      }
    },
    "content": {
      "type": "array",
      "items": { "$ref": "#/definitions/contentItem" },
      "description": "The root content array of the document."
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Citation tag, e.g., 'Smith2024'" },
          "citation": { "type": "string", "description": "Full citation string. Supports Typst markup." }
        },
        "required": ["id", "citation"]
      }
    }
  },
  "required": ["title", "authors", "content"],

  "definitions": {
    "contentItem": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "type": { "enum": ["section", "subsection", "subsubsection"] },
            "title": { "type": "string", "description": "Heading text." },
            "content": {
              "type": "array",
              "items": { "$ref": "#/definitions/contentItem" },
              "description": "Nested items inside this section."
            }
          },
          "required": ["type", "title"]
        },
        {
          "properties": {
            "type": { "const": "paragraph" },
            "text": { "type": "string", "description": "Paragraph body text." }
          },
          "required": ["type", "text"]
        },
        {
          "properties": {
            "type": { "const": "equation" },
            "math": { "type": "string", "description": "Typst math syntax." }
          },
          "required": ["type", "math"]
        },
        {
          "properties": {
            "type": { "const": "image" },
            "src": { "type": "string", "description": "Path to image file." },
            "caption": { "type": "string" },
            "width": { "type": "string" }
          },
          "required": ["type", "src"]
        },
        {
          "properties": {
            "type": { "const": "table" },
            "columns": { "type": "integer" },
            "caption": { "type": "string" },
            "headers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "data": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "required": ["type", "columns", "data"]
        }
      ]
    }
  }
}